# Example environment for the auth-app stack (bead authapp-242382).
#
# Copy to `.env` and adjust — `docker compose` auto-loads `./.env`:
#
#   cp .env.example .env
#   docker compose --profile dev up --build
#
# The values here are DEV placeholders, safe to commit as an example. They are
# NOT secrets — change every password/secret before any real deployment, and in
# production supply secrets via Docker secrets (see compose.prod.yml), not this
# file. `.env` itself is git-ignored.
#
# Legend:  (required) must be set   ·   default shown when a variable is optional.

# ─── Edge / Traefik ──────────────────────────────────────────────────────────
# Public hostname the app is served on; Traefik routes this host and requests a
# Let's Encrypt certificate for it. `localhost` is fine for local dev (no cert).
APP_DOMAIN=localhost
# Contact address on the issued TLS certificates. (required by the edge stack)
ACME_EMAIL=you@example.com

# ─── Application (API) ───────────────────────────────────────────────────────
# Address the API binds inside its container (compose sets 0.0.0.0:8080).
APP_HOST=0.0.0.0
APP_PORT=8080
# Comma-separated browser origins allowed by CORS (never a wildcard). Empty in a
# same-origin deployment behind Traefik.
CORS_ALLOWED_ORIGINS=
# Log level / filter for the JSON logs (tracing EnvFilter). default: info
RUST_LOG=info

# ─── Database (API connection) ───────────────────────────────────────────────
# Connection string the API uses. In compose this is composed from the app role
# + password below; set it directly only when running the API without compose.
# In production prefer DATABASE_URL_FILE (a Docker secret) over a plain value.
# DATABASE_URL=postgres://authapp_app:change-me@localhost:5432/authapp?sslmode=disable
# DATABASE_URL_FILE=/run/secrets/database_url
# Pool tuning (optional).  defaults: 10 / 0 / 30
DATABASE_MAX_CONNECTIONS=10
DATABASE_MIN_CONNECTIONS=0
DATABASE_ACQUIRE_TIMEOUT_SECS=30

# ─── Postgres container (compose) ────────────────────────────────────────────
# Bootstrap superuser — used only for administration/migrations/backups, never
# by the app. (POSTGRES_SUPERUSER_PASSWORD required)
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=change-me-superuser
POSTGRES_DB=authapp
# Least-privilege application role the API connects as. (APP_DB_PASSWORD required)
APP_DB_USER=authapp_app
APP_DB_PASSWORD=change-me-app
# Scheduled-backup sidecar (compose `--profile backup`).  defaults: 86400 / 7
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION=7

# ─── First administrator (bootstrap-admin) ───────────────────────────────────
# Used by `server bootstrap-admin` (the dev compose runs it once). The password
# must satisfy the policy below. (ADMIN_BOOTSTRAP_PASSWORD required to bootstrap)
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-Str0ng!

# ─── Production images (compose.prod.yml) ────────────────────────────────────
# Versioned, registry-hosted image tags for prod (no local build). (required for prod)
# API_IMAGE=ghcr.io/your-org/auth-app-api:v1.0.0
# WEB_IMAGE=ghcr.io/your-org/auth-app-web:v1.0.0

# ─── Password hashing (Argon2id) ─────────────────────────────────────────────
# OWASP-recommended defaults are used when unset. Tune only with benchmarking.
# ARGON2_MEMORY_KIB=19456
# ARGON2_ITERATIONS=2
# ARGON2_PARALLELISM=1

# ─── Admin password policy ───────────────────────────────────────────────────
# Sensible defaults apply when unset.
# ADMIN_PASSWORD_MIN_LENGTH=12
# ADMIN_PASSWORD_REQUIRE_UPPERCASE=true
# ADMIN_PASSWORD_REQUIRE_LOWERCASE=true
# ADMIN_PASSWORD_REQUIRE_DIGIT=true
# ADMIN_PASSWORD_REQUIRE_SYMBOL=true

# ─── Account/IP lockout ──────────────────────────────────────────────────────
# ADMIN_LOCKOUT_MAX_ATTEMPTS=5
# ADMIN_LOCKOUT_BASE_SECONDS=30
# ADMIN_LOCKOUT_MAX_SECONDS=3600

# ─── Sessions ────────────────────────────────────────────────────────────────
# SESSION_IDLE_TIMEOUT_SECS=1800
# SESSION_ABSOLUTE_TIMEOUT_SECS=43200

# ─── Payments (optional) ─────────────────────────────────────────────────────
# Provider selection: disabled | fake | stripe.  default: disabled
# `fake` is a deterministic in-memory provider for local dev; `stripe` needs the
# keys below.
PAYMENT_PROVIDER=fake
# STRIPE_SECRET_KEY=sk_live_change-me           # (required when PAYMENT_PROVIDER=stripe)
# STRIPE_API_BASE=https://api.stripe.com        # override for testing only
# STRIPE_WEBHOOK_SECRET=whsec_change-me          # enables the signed webhook endpoint

# ─── OAuth2 / OIDC sign-in (optional) ────────────────────────────────────────
# Comma-separated provider ids to enable (e.g. `google`). Leave empty to disable
# OAuth entirely (the login page then shows no provider buttons).
OAUTH_PROVIDERS=
# Externally reachable base the provider redirects back to (usually your APP_DOMAIN).
# OAUTH_REDIRECT_BASE=https://localhost
# Where the SPA lands after sign-in.  defaults: / and /login
# OAUTH_SUCCESS_REDIRECT=/
# OAUTH_FAILURE_REDIRECT=/login
# Per-provider settings — repeat for each id in OAUTH_PROVIDERS, uppercased.
# For OAUTH_PROVIDERS=google:
# OAUTH_GOOGLE_CLIENT_ID=change-me
# OAUTH_GOOGLE_CLIENT_SECRET=change-me
# OAUTH_GOOGLE_AUTH_ENDPOINT=https://accounts.google.com/o/oauth2/v2/auth
# OAUTH_GOOGLE_TOKEN_ENDPOINT=https://oauth2.googleapis.com/token
# OAUTH_GOOGLE_USERINFO_ENDPOINT=https://openidconnect.googleapis.com/v1/userinfo
# OAUTH_GOOGLE_ISSUER=https://accounts.google.com
# OAUTH_GOOGLE_SCOPES=openid,email
