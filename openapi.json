{
  "openapi": "3.1.0",
  "info": {
    "title": "auth-app API",
    "description": "The JSON API the admin frontend consumes.",
    "contact": {
      "name": "auth-app template"
    },
    "license": {
      "name": "MIT",
      "identifier": "MIT"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/audit/events": {
      "get": {
        "tags": [
          "audit"
        ],
        "summary": "Handle `GET /audit/events?limit=`: the most recent audit events, newest\nfirst, capped at [`MAX_LIMIT`] regardless of what the caller asks for.",
        "operationId": "list_events",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of events to return (default 50, capped at 200).",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent audit events, newest first",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/EventOut"
                  }
                }
              }
            }
          },
          "401": {
            "description": "No valid session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Authenticated but not the admin role",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Handle `POST /auth/login`.",
        "description": "`200` with the admin id and fresh session/CSRF cookies on success; `401`\nfor invalid credentials (identical for a wrong password and a nonexistent\naccount); `429` with `Retry-After` when the IP or account has hit the\napp-level rate limit, or when the account/IP is locked out (see\n[`LoginError::TooManyAttempts`] — a distinct mechanism from the rate limit:\nlockout counts *failures*, the rate limit counts *every* attempt); `500` on\nan internal failure. Every successful login issues a brand-new session —\nthere is no \"reuse the prior session\" path — which is what satisfies\nsession rotation on login.",
        "operationId": "login_handler",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Signed in; sets session and csrf cookies",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginOk"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials (wrong password or unknown account)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Malformed request (per-field validation)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate-limited or locked out; carries Retry-After",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Handle `POST /auth/logout`: revoke the session server-side, record the\nevent to the audit trail, and clear both cookies. Requires (via\n[`require_session`]) a valid session and a matching CSRF header — logout\nis a mutation like any other.",
        "operationId": "logout_handler",
        "responses": {
          "204": {
            "description": "Logged out; clears the session and csrf cookies"
          },
          "401": {
            "description": "No valid session"
          },
          "403": {
            "description": "Missing or mismatched CSRF header"
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "Handle `GET /auth/me`: report the authenticated admin's id and role, so\nfrontend guards can hide routes/actions the role does not permit without\na separate round trip. Any authenticated role may call this — it is not\nitself role-gated (see [`crate::rbac::require_role`] for endpoints that\nare).",
        "operationId": "me_handler",
        "responses": {
          "200": {
            "description": "The authenticated admin's id and role",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeOut"
                }
              }
            }
          },
          "401": {
            "description": "No valid session"
          }
        }
      }
    },
    "/auth/oauth/providers": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "`GET /auth/oauth/providers`: list the enabled provider ids. Public — the\nlogin page calls it before any session exists.",
        "operationId": "providers_handler",
        "responses": {
          "200": {
            "description": "The enabled OAuth provider ids",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProvidersOut"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Liveness probe: `200 OK` whenever the process is running. No dependency is\nchecked, so a slow or briefly-unreachable database never turns into a restart.",
        "operationId": "liveness_handler",
        "responses": {
          "200": {
            "description": "The process is alive"
          }
        }
      }
    },
    "/ready": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Readiness probe: `200 OK` when ready, `503 Service Unavailable` otherwise.",
        "description": "Awaits the application service, which in turn probes the live database, so a\ndown or unreachable Postgres surfaces here as `503`.",
        "operationId": "readiness_handler",
        "responses": {
          "200": {
            "description": "Ready to serve"
          },
          "503": {
            "description": "Not ready (database unreachable)"
          }
        }
      }
    },
    "/transactions": {
      "get": {
        "tags": [
          "transactions"
        ],
        "summary": "Handle `GET /transactions`: a filtered, paginated payment list, newest\nfirst.",
        "operationId": "list_transactions",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "Only payments in this status (e.g. `captured`, `refunded`).",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "created_after",
            "in": "query",
            "description": "Only payments created at or after this Unix epoch second (inclusive).",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "created_before",
            "in": "query",
            "description": "Only payments created strictly before this Unix epoch second.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Page size (default 50, capped at 200).",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Rows to skip, for paging (default 0).",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "One page of transactions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionPage"
                }
              }
            }
          },
          "401": {
            "description": "No valid session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Invalid status filter (per-field)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/transactions/{id}": {
      "get": {
        "tags": [
          "transactions"
        ],
        "summary": "Handle `GET /transactions/{id}`: one payment with its full status history.",
        "operationId": "get_transaction",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The payment id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The payment and its status history",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionDetailOut"
                }
              }
            }
          },
          "401": {
            "description": "No valid session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "No such payment",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/transactions/{id}/refund": {
      "post": {
        "tags": [
          "transactions"
        ],
        "summary": "Handle `POST /transactions/{id}/refund`: refund a captured payment in full.\nAdmin-only (via [`require_role`]) and CSRF-checked (via [`require_session`]).",
        "operationId": "refund_transaction",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The payment id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Refunded; the payment's new status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RefundOut"
                }
              }
            }
          },
          "401": {
            "description": "No valid session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Not the admin role, or missing/mismatched CSRF",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "No such payment",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Payment is not in a refundable state",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "The provider declined the refund",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "The provider was unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "description": "The JSON body every error response carries.",
        "required": [
          "code",
          "message",
          "trace_id"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "A stable, machine-readable error code (e.g. `unauthorized`,\n`not_found`, `validation_failed`)."
          },
          "fields": {
            "type": [
              "object",
              "null"
            ],
            "description": "Per-field validation messages, present only on a `422` response.",
            "additionalProperties": {
              "type": "string"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "message": {
            "type": "string",
            "description": "A human-readable, client-safe message. Never contains internal detail."
          },
          "trace_id": {
            "type": "string",
            "description": "A correlation id, also logged server-side, so a client-reported error\ncan be matched to its log line."
          }
        }
      },
      "EventOut": {
        "type": "object",
        "description": "One audit event, as returned to the admin panel.",
        "required": [
          "id",
          "event_type",
          "ip",
          "occurred_at_epoch"
        ],
        "properties": {
          "admin_id": {
            "type": [
              "string",
              "null"
            ],
            "description": "The resolved admin id, when the event maps to a known account."
          },
          "email_attempted": {
            "type": [
              "string",
              "null"
            ],
            "description": "The email submitted, for login events (kept even when it matched no\naccount)."
          },
          "event_type": {
            "type": "string",
            "description": "The event type (`login_succeeded`, `login_failed`, `locked_out`,\n`logged_out`)."
          },
          "id": {
            "type": "string",
            "description": "The event's opaque id."
          },
          "ip": {
            "type": "string",
            "description": "The client IP the request came from."
          },
          "occurred_at_epoch": {
            "type": "integer",
            "format": "int64",
            "description": "When the event happened, as Unix epoch seconds.",
            "minimum": 0
          },
          "user_agent": {
            "type": [
              "string",
              "null"
            ],
            "description": "The client `User-Agent`, if any."
          }
        }
      },
      "LoginBody": {
        "type": "object",
        "description": "The JSON body of a login request.",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "description": "The administrator's email address.",
            "example": "admin@example.com"
          },
          "password": {
            "type": "string",
            "description": "The administrator's password."
          }
        }
      },
      "LoginOk": {
        "type": "object",
        "description": "The success body: the authenticated administrator's id.",
        "required": [
          "admin_id"
        ],
        "properties": {
          "admin_id": {
            "type": "string",
            "description": "The authenticated administrator's opaque id."
          }
        }
      },
      "MeOut": {
        "type": "object",
        "description": "The body `GET /auth/me` returns: enough for the frontend to know who is\nlogged in and which role's guards to apply.",
        "required": [
          "admin_id",
          "role"
        ],
        "properties": {
          "admin_id": {
            "type": "string",
            "description": "The authenticated administrator's opaque id."
          },
          "role": {
            "type": "string",
            "description": "The administrator's role (e.g. `admin`)."
          }
        }
      },
      "ProvidersOut": {
        "type": "object",
        "description": "The configured OAuth providers, for the login UI to render a button per one.",
        "required": [
          "providers"
        ],
        "properties": {
          "providers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "The enabled provider ids (e.g. `[\"google\"]`), sorted. Empty when OAuth\nis configured but has no providers; the whole route is absent (`404`)\nwhen OAuth is disabled entirely — the UI treats both as \"no providers\"."
          }
        }
      },
      "RefundOut": {
        "type": "object",
        "description": "The result of a successful refund.",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string",
            "description": "The status the payment moved to (`refunded` or `partially_refunded`)."
          }
        }
      },
      "StatusChangeOut": {
        "type": "object",
        "description": "One recorded status change in a payment's history.",
        "required": [
          "to",
          "occurred_at_epoch"
        ],
        "properties": {
          "from": {
            "type": [
              "string",
              "null"
            ],
            "description": "The prior status, or `null` for the row recording creation."
          },
          "occurred_at_epoch": {
            "type": "integer",
            "format": "int64",
            "description": "When the transition happened, as Unix epoch seconds.",
            "minimum": 0
          },
          "reason": {
            "type": [
              "string",
              "null"
            ],
            "description": "An optional human-readable reason (a decline code, `admin_refund`, ...)."
          },
          "to": {
            "type": "string",
            "description": "The status moved to."
          }
        }
      },
      "TransactionDetailOut": {
        "type": "object",
        "description": "A payment with its full status history — the detail view's payload.",
        "required": [
          "transaction",
          "history"
        ],
        "properties": {
          "history": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StatusChangeOut"
            },
            "description": "Every recorded status change, oldest first."
          },
          "transaction": {
            "$ref": "#/components/schemas/TransactionOut",
            "description": "The payment itself."
          }
        }
      },
      "TransactionOut": {
        "type": "object",
        "description": "One payment row, as returned to the admin panel.",
        "required": [
          "id",
          "amount_minor_units",
          "currency",
          "status",
          "created_at_epoch",
          "updated_at_epoch"
        ],
        "properties": {
          "amount_minor_units": {
            "type": "integer",
            "format": "int64",
            "description": "The amount, in the currency's minor units (e.g. cents) — never a float."
          },
          "created_at_epoch": {
            "type": "integer",
            "format": "int64",
            "description": "When the payment was created, as Unix epoch seconds.",
            "minimum": 0
          },
          "currency": {
            "type": "string",
            "description": "ISO 4217 currency code (`USD`, ...)."
          },
          "id": {
            "type": "string",
            "description": "The payment's opaque id (its primary key)."
          },
          "provider_reference": {
            "type": [
              "string",
              "null"
            ],
            "description": "The provider's reference, once one exists."
          },
          "status": {
            "type": "string",
            "description": "The current status (`created`, `captured`, `refunded`, ...)."
          },
          "updated_at_epoch": {
            "type": "integer",
            "format": "int64",
            "description": "When the payment's status last changed, as Unix epoch seconds.",
            "minimum": 0
          }
        }
      },
      "TransactionPage": {
        "type": "object",
        "description": "One page of transactions plus the total matching the filter.",
        "required": [
          "items",
          "total",
          "limit",
          "offset"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TransactionOut"
            },
            "description": "The payments on this page, newest first."
          },
          "limit": {
            "type": "integer",
            "format": "int32",
            "description": "The page size that was applied (after capping).",
            "minimum": 0
          },
          "offset": {
            "type": "integer",
            "format": "int32",
            "description": "The offset that was applied.",
            "minimum": 0
          },
          "total": {
            "type": "integer",
            "format": "int64",
            "description": "Total payments matching the filter across all pages.",
            "minimum": 0
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "auth",
      "description": "Sign-in, session, and identity"
    },
    {
      "name": "audit",
      "description": "Authentication audit trail"
    },
    {
      "name": "transactions",
      "description": "Payment transactions and refunds"
    },
    {
      "name": "health",
      "description": "Readiness probe"
    }
  ]
}
